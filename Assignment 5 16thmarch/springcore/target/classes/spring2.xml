<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="
 http://www.springframework.org/schema/beans
 http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Problem 1 Bean -->

    <bean id="emp" class="cg.demos.springcore.problem1.Employee">

        <property name="employeeId" value="12345"/>
        <property name="employeeName" value="Harriet"/>
        <property name="salary" value="40000"/>
        <property name="businessUnit" value="PES-BU"/>
        <property name="age" value="30"/>

    </bean>


    <!-- Problem 2 Beans -->

    <bean id="sbu1" class="cg.demos.springcore.problem2.SBU">

        <property name="sbuId" value="101"/>
        <property name="sbuName" value="Product Engineering Services"/>
        <property name="sbuHead" value="Kiran Rao"/>

    </bean>


    <bean id="emp1" class="cg.demos.springcore.problem2.Employee">

        <property name="employeeId" value="12345"/>
        <property name="employeeName" value="Harriet"/>
        <property name="salary" value="40000"/>
        <property name="age" value="30"/>

        <property name="businessUnit" ref="sbu1"/>

    </bean>

</beans>